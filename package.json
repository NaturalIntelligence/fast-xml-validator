{
  "name": "fast-xml-validator",
  "version": "1.0.0",
  "description": "Validate XML for Syntax and Business rules without C/C++ based libraries",
  "main": "./lib/fxv.cjs",
  "type": "module",
  "sideEffects": false,
  "module": "./src/fxv.js",
  "types": "./src/fxv.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./src/fxv.d.ts",
        "default": "./src/fxv.js"
      },
      "require": {
        "types": "./lib/fxv.d.cts",
        "default": "./lib/fxv.cjs"
      }
    }
  },
  "scripts": {
    "test": "c8 --reporter=lcov --reporter=text jasmine specs/*spec.js",
    "bundle": "webpack --config webpack.cjs.config.js"
  },
  "files": [
    "lib",
    "src",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NaturalIntelligence/fast-xml-validator.git"
  },
  "keywords": [
    "fast",
    "xml",
    "validator",
    "validate",
    "syntax",
    "rules",
    "business"
  ],
  "author": "Amit Gupta (https://solothought.com)",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.13.10",
    "@babel/plugin-transform-runtime": "^7.13.10",
    "@babel/preset-env": "^7.13.10",
    "@babel/register": "^7.13.8",
    "@types/node": "20",
    "babel-loader": "^8.2.2",
    "c8": "^10.1.3",
    "eslint": "^8.3.0",
    "jasmine": "^5.6.0",
    "typescript": "5",
    "webpack": "^5.64.4",
    "webpack-cli": "^4.9.1"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/NaturalIntelligence"
    }
  ],
  "dependencies": {
    "detailed-xml-validator": "^2.1.0"
  }
}